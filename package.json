{
  "name": "@dandehoon/unimcp",
  "version": "1.0.1",
  "description": "A local MCP aggregator that merges multiple MCP servers into a single unified endpoint.",
  "main": "index.js",
  "bin": {
    "unimcp": "./bin/unimcp.js"
  },
  "files": [
    "src/",
    "bin/",
    "dist/unimcp.js",
    "README.md"
  ],
  "scripts": {
    "test": "bun test tests/",
    "typecheck": "tsc --noEmit",
    "register": "bun run src/index.ts setup",
    "register-node": "node bin/unimcp.js setup",
    "collect": "bun run src/index.ts collect",
    "dev": "bun run src/index.ts",
    "http": "bun run src/index.ts --http",
    "daemon": "bun run src/index.ts --daemon",
    "bundle": "bun build --bundle --target=node --minify --outfile dist/unimcp.js src/index.ts",
    "build": "bun build --compile --minify src/index.ts --outfile dist/unimcp && rm -f ./*.bun-build",
    "install-bin": "pnpm build && cp dist/unimcp /usr/local/bin/unimcp && codesign --force --deep --sign - /usr/local/bin/unimcp"
  },
  "keywords": [],
  "author": "dandehoon <nguyenbao1917@gmail.com>",
  "license": "ISC",
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "chokidar": "^5.0.0",
    "minimatch": "^10.2.5"
  },
  "packageManager": "pnpm@10.18.2",
  "devDependencies": {
    "@types/node": "^25.5.2",
    "typescript": "^6.0.2"
  },
  "pnpm": {
    "overrides": {
      "hono": ">=4.12.12",
      "@hono/node-server": ">=1.19.13"
    }
  }
}
