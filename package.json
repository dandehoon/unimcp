{
  "name": "unimcp",
  "version": "1.0.0",
  "description": "A local MCP aggregator that merges multiple MCP servers into a single unified endpoint.",
  "main": "index.js",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "typecheck": "tsc --noEmit",
    "register": "bun run src/index.ts setup",
    "dev": "bun run src/index.ts",
    "http": "bun run src/index.ts --http",
    "daemon": "bun run src/index.ts --daemon",
    "build": "bun build --compile --minify src/index.ts --outfile dist/unimcp",
    "install-bin": "pnpm build && sudo cp dist/unimcp /usr/local/bin/unimcp"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "chokidar": "^5.0.0",
    "dotenv": "^17.3.1",
    "minimatch": "^10.2.5"
  },
  "packageManager": "pnpm@10.18.2",
  "devDependencies": {
    "@types/node": "^25.5.0",
    "typescript": "^6.0.2"
  }
}
